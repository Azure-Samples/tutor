FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
	PYTHONUNBUFFERED=1

WORKDIR /workspace

COPY lib ./lib
COPY apps/upskilling ./apps/upskilling

RUN pip install --no-cache-dir --upgrade pip \
	&& pip install --no-cache-dir -e ./lib -e ./apps/upskilling

WORKDIR /workspace/apps/upskilling

CMD ["sh", "-c", "uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}"]
