FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /workspace

COPY lib ./lib
COPY apps/lms-gateway ./apps/lms-gateway

RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -e ./lib -e ./apps/lms-gateway

WORKDIR /workspace/apps/lms-gateway/src

CMD ["sh", "-c", "uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}"]
