{
    "git.confirmSync": true,
    "git.enableSmartCommit": true,
    "git.autofetch": true,
    "debug.onTaskErrors": "debugAnyway",
    "terminal.integrated.enableMultiLinePasteWarning": false,
    "window.zoomLevel": 0,
    "javascript.updateImportsOnFileMove.enabled": "always",
    "C_Cpp.autocompleteAddParentheses": true,
    "C_Cpp.default.includePath": [
        "${workspaceFolder}/**"
    ],
    "autoDocstring.includeExtendedSummary": false,
    "autoDocstring.includeName": false,
    "autoDocstring.startOnNewLine": true,
    "python.analysis.autoImportCompletions": true,
    "python.analysis.completeFunctionParens": true,
    "python.analysis.diagnosticMode": "workspace",
    "python.analysis.fixAll": [],
    "python.analysis.extraPaths": [
      "${workspaceFolder}/lib/src",
      "${workspaceFolder}/apps/questions/app",
      "${workspaceFolder}/apps/upskilling/app",
      "${workspaceFolder}/apps/configuration/src"
    ],
    "python.analysis.indexing": false,
    "python.analysis.typeCheckingMode": "basic",
    "python.defaultInterpreterPath": "${workspaceFolder}\\.venv\\Scripts\\python",
    "python.analysis.packageIndexDepths": [
        {
          "name": "promptflow",
          "depth": 2
        },
        {
          "name": "fastapi",
          "depth": 2
        },
      ],
    "python.analysis.inlayHints.functionReturnTypes": true,
    "python.analysis.inlayHints.variableTypes": true,
    "search.useIgnoreFiles": true,
    "python.terminal.activateEnvironment": true,
    "python.testing.pytestArgs": [
      "tests"
    ],
    "python.testing.unittestEnabled": false,
    "python.testing.pytestEnabled": true,
    "chat.tools.terminal.autoApprove": {
      "terraform": true,
      "azd": true,
      "az": true,
      "ConvertFrom-Json": true,
      "ForEach-Object": true
    }
}