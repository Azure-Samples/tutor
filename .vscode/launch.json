{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Avatar",
      "type": "debugpy",
      "cwd": "${workspaceFolder}\\apps\\avatar\\src",
      "request": "launch",
      "module": "uvicorn",
      "python": "${workspaceFolder}\\apps\\avatar\\.venv\\Scripts\\python.exe",
      "env": {
        "Path": "${env:Path};${workspaceFolder}\\apps\\avatar"
      },
      "args": ["app.main:app", "--reload", "--port", "8084"],
      "jinja": true,
      "justMyCode": false
    },
    {
      "name": "Essay",
      "type": "debugpy",
      "cwd": "${workspaceFolder}\\src\\essays",
      "request": "launch",
      "module": "uvicorn",
      "python": "${workspaceFolder}\\apps\\essays\\.venv\\Scripts\\python.exe",
      "env": {
        "Path": "${env:Path};${workspaceFolder}\\src"
      },
      "args": ["app.main:app", "--reload", "--port", "8083"],
      "jinja": true,
      "justMyCode": false
    },
    {
      "name": "Questions",
      "type": "debugpy",
      "cwd": "${workspaceFolder}\\src\\questions",
      "request": "launch",
      "module": "uvicorn",
      "python": "${workspaceFolder}\\apps\\questions\\.venv\\Scripts\\python.exe",
      "env": {
        "Path": "${env:Path};${workspaceFolder}\\src"
      },
      "args": ["app.main:app", "--reload", "--port", "8082"],
      "jinja": true,
      "justMyCode": false
    },
    {
      "name": "Configuration",
      "type": "debugpy",
      "cwd": "${workspaceFolder}\\src\\configuration",
      "request": "launch",
      "module": "uvicorn",
      "python": "${workspaceFolder}\\apps\\configuration\\.venv\\Scripts\\python.exe",
      "env": {
        "Path": "${env:Path};${workspaceFolder}\\src"
      },
      "args": ["app.main:app", "--reload", "--port", "8081"],
      "jinja": true,
      "justMyCode": false
    },
    {
      "name": "Frontend",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}\\src\\frontend",
      "runtimeExecutable": "yarn",
      "runtimeArgs": ["dev"],
      "console": "integratedTerminal"
    },
    {
      "name": "Essay Demo Debugger",
      "type": "debugpy",
      "cwd": "${workspaceFolder}\\src\\essays",
      "request": "launch",
      "program": "${file}",
      "python": "${workspaceFolder}\\apps\\essays\\.venv\\Scripts\\python.exe"
    }
  ]
}
